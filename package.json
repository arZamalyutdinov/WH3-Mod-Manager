{
  "name": "wh3mm",
  "productName": "wh3mm",
  "version": "2.17.9",
  "description": "WH3 Mod Manager",
  "main": ".webpack/main",
  "sideEffects": [
    "*.css",
    "*.scss",
    "src/index.css",
    "src/renderer.ts",
    "src/schema.ts",
    "src/app.tsx",
    "handsontable/styles/*.css"
  ],
  "scripts": {
    "start": "tsc ./src/sub.ts ./src/readPacksWorker.ts ./src/packSearchWorker.ts --skipLibCheck --resolveJsonModule --outDir ./temp && electron-forge start --inspect-electron -- --mode development",
    "dbclone": "tsc ./src/sub.ts ./src/readPacksWorker.ts ./src/packSearchWorker.ts --skipLibCheck --resolveJsonModule --outDir ./temp && electron-forge start --inspect-electron -- --mode development -testDBClone",
    "package": "electron-forge package",
    "make": "tsc ./src/sub.ts ./src/readPacksWorker.ts ./src/packSearchWorker.ts --skipLibCheck --resolveJsonModule --outDir ./temp && electron-forge make -- --mode production",
    "publish": "electron-forge publish",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint --ext .ts,.tsx .",
    "storybook": "echo 'storybook currently broken, storybook dev -p 6006'",
    "build-storybook": "storybook build",
    "typecheck": "tsc --noEmit",
    "test:unit": "node --test --experimental-strip-types --loader ./test/tsExtensionResolver.loader.mjs test/*.test.ts"
  },
  "keywords": [],
  "author": {
    "name": "Tibor Ilić",
    "email": "tilic5@gmail.com"
  },
  "license": "MIT",
  "config": {
    "forge": {
      "packagerConfig": {
        "icon": "./src/assets/modmanager.ico"
      },
      "publishers": [
        {
          "name": "@electron-forge/publisher-github",
          "config": {
            "repository": {
              "owner": "arZamalyutdinov",
              "name": "WH3-Mod-Manager"
            }
          }
        }
      ],
      "makers": [
        {
          "name": "@electron-forge/maker-zip"
        },
        {
          "name": "@electron-forge/maker-zip",
          "platforms": [
            "darwin"
          ]
        },
        {
          "name": "@electron-forge/maker-deb",
          "config": {}
        },
        {
          "name": "@electron-forge/maker-rpm",
          "config": {}
        }
      ],
      "plugins": [
        {
          "name": "@electron-forge/plugin-webpack",
          "config": {
            "mainConfig": "./webpack.main.config.js",
            "renderer": {
              "config": "./webpack.renderer.config.js",
              "entryPoints": [
                {
                  "html": "./src/index.html",
                  "js": "./src/renderer.ts",
                  "name": "main_window",
                  "preload": {
                    "js": "./src/preload.ts"
                  }
                },
                {
                  "html": "./src/viewer/viewerIndex.html",
                  "js": "./src/renderer.ts",
                  "name": "viewer",
                  "preload": {
                    "js": "./src/preload.ts"
                  }
                },
                {
                  "html": "./src/viewer/viewerIndex.html",
                  "js": "./src/renderer.ts",
                  "name": "skills",
                  "preload": {
                    "js": "./src/preload.ts"
                  }
                }
              ]
            }
          }
        }
      ]
    }
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@chromatic-com/storybook": "^3.2.2",
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-webpack": "^7.11.1",
    "@pmmmwh/react-refresh-webpack-plugin": "^0.6.2",
    "@storybook/addon-actions": "^8.6.14",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/addon-links": "^8.6.14",
    "@storybook/addon-mdx-gfm": "^8.6.14",
    "@storybook/addon-styling-webpack": "^1.0.1",
    "@storybook/addon-themes": "^8.6.14",
    "@storybook/addon-webpack5-compiler-swc": "^1.0.5",
    "@storybook/react": "^8.6.14",
    "@storybook/react-webpack5": "^8.6.14",
    "@storybook/test": "^8.6.14",
    "@types/binary-file": "^0.2.2",
    "@types/clone-deep": "^4.0.4",
    "@types/fs-extra": "^11.0.4",
    "@types/luaparse": "^0.2.13",
    "@types/nightmare": "^2.10.9",
    "@types/object-hash": "^3.0.6",
    "@types/object.groupby": "^1.0.4",
    "@types/react": "^18.3.22",
    "@types/react-dom": "^18.3.7",
    "@types/react-virtualized": "^9.22.3",
    "@types/unzipper": "^0.10.11",
    "@types/winreg": "^1.2.36",
